    "engines": {
        "vscode": "^1.54.3"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:extension.linkcode"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.linkcode",
                "title": "linkmklink"
            }
        ],
        "keybindings": [
            {
                "command": "extension.linkcode",
                "key": "ctrl+f8",
                "mac": "cmd+f8",
                "when": "filesExplorerFocus"
            }
        ],
        "menus": {
            "explorer/context": [
                {
                    "command": "extension.linkcode"
                }
            ],
            "editor/title/context": [
                {
                    "command": "extension.linkcode"
                }
            ]
        }
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "node ./test/runTest.js"
    },

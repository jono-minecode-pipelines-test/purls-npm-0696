    "engines": {
        "vscode": "^1.54.3"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:extension.linkcode"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "extension.linkcode",
                "title": "linkmklink"
            }
        ],
        "keybindings": [
